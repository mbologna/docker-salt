# SaltStack minion on a pinned openSUSE Leap base.
# Renovate keeps the base image digest and packages up to date.
FROM opensuse/leap:42.3@sha256:271c921a1c84d65467d565e3f1c754b75aa01ceed1a7ac39de4816683c355fd2

LABEL maintainer="Michele Bologna <mb@michelebologna.net>" \
      org.opencontainers.image.title="saltstack-minion" \
      org.opencontainers.image.description="SaltStack minion preconfigured to reach a master at the host 'salt'" \
      org.opencontainers.image.source="https://github.com/mbologna/docker-salt" \
      org.opencontainers.image.licenses="MIT"

# hadolint ignore=DL3037
RUN zypper --non-interactive install --no-recommends salt-minion && \
    zypper clean --all

# Explicitly point the minion at a master reachable as "salt".
# This preserves compatibility with `docker run --link saltmaster:salt` and the
# `salt` network alias used by docker-compose / the salt-netapi-client CI.
COPY etc_minion/salt/minion.d/master.conf /etc/salt/minion.d/master.conf

ENTRYPOINT ["/usr/bin/salt-minion"]
CMD ["-l", "debug"]
